---
export interface Props {
  title: string;
  role?: string;
  date?: string;
  description: string;
  tags: string[];
}
const { title, role, date, description, tags } = Astro.props;
---
<div class="bg-base-light p-6 rounded-2xl border border-transparent hover:border-primary/30 transition-all duration-300 group flex flex-col gap-4 shadow-xl hover:-translate-y-1">
  <div>
    <h3 class="text-2xl font-semibold text-text-main group-hover:text-primary transition-colors">{title}</h3>
    {role && <p class="text-sm font-mono text-accent">{role}</p>}
    {date && <p class="text-xs text-text-muted">{date}</p>}
  </div>
  <p class="text-text-muted flex-grow">{description}</p>
  <div class="flex flex-wrap gap-2 pt-2 border-t border-base">
    {tags.map((tag) => (
      <span class="px-3 py-1 bg-base text-xs font-mono text-text-muted rounded-full group-hover:text-accent transition">{tag}</span>
    ))}
  </div>
</div>